{
  "name": "rustpets",
  "displayName": "RustPets",
  "description": "Visualizing Rust ownership and borrowing as animated creatures.",
  "version": "0.1.0",
  "publisher": "picklerick",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rustpets.showTheatre",
        "title": "RustPets: Show Ownership Theatre"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --target=node18",
    "watch": "npm run build -- --watch",
    "compile": "tsc -p ./",
    "build:analyzer": "cd analyzer && cargo build --release && (if not exist ..\\bin mkdir ..\\bin) && (copy /y target\\release\\rustpets-analyzer.exe ..\\bin\\ || cp target/release/rustpets-analyzer ../bin/)",
    "build:all": "npm run build && npm run build:analyzer",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "18.x",
    "typescript": "^5.3.3",
    "esbuild": "^0.19.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0"
  }
}
